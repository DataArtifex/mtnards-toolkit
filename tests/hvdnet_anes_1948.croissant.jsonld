    "@type": "sc:Dataset",
    "name": "ANES 1948 Time Series Study",
    "description": "This study is part of a time\\-series collection of national surveys fielded continuously since 1952\\. The election studies are designed to present data on Americans' social backgrounds, enduring political predispositions, social and political values, perceptions and evaluations of groups and candidates, opinions on questions of public policy, and participation in political life.",
    "conformsTo": "http://mlcommons.org/croissant/1.0",
    "citeAs": "<p>Campbell, Angus, and Kahn, Robert L. ANES 1948 Time Series Study. Ann Arbor, MI: Inter-university Consortium for Political and Social Research [distributor], 2015-11-10. https://doi.org/10.3886/ICPSR07218.v4</p>",
    "dateModified": "2025-04-08 17:35:15.530000+00:00",
    "isLiveDataset": true,
    "url": "https://rds.highvaluedata.net/rds/explorer/explore/us-anes/anes1948",
    "version": "11.0.0",
